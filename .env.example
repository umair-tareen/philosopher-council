# --- Providers (set the keys for whichever you use) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5
# OPENAI_API_KEY=sk-...
# Point openai: specs at any OpenAI-compatible endpoint (free options abound):
# OPENAI_BASE_URL=https://openrouter.ai/api/v1      (OpenRouter - has free models)
# OPENAI_BASE_URL=http://localhost:1234/v1          (LM Studio - local, no key)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1    (Groq - free tier)
# GEMINI_API_KEY=...
# OLLAMA_BASE_URL=http://localhost:11434

# --- Model routing ---
# Default model for every seat, as "provider:model". Falls back to anthropic:<ANTHROPIC_MODEL>.
# DEFAULT_MODEL=anthropic:claude-sonnet-4-5
# Per-seat overrides (philosopher ids, plus "ibnarabi" and "ralph"):
# COUNCIL_MODELS=laotzu=ollama:llama3.1,kant=openai:gpt-4o,ralph=anthropic:claude-haiku-4-5-20251001

# --- Pipeline ---
CRON_EXPR=0 */6 * * *
SOURCES_REDDIT=LocalLLaMA,MachineLearning,singularity
MAX_ITEMS_PER_RUN=10
DRY_RUN=0
DATA_DIR=./data
LOG_LEVEL=info
