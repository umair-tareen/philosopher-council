{
  "name": "stoic-ai-council",
  "version": "0.1.0",
  "description": "An eleven-philosopher council that analyses current AI-research trends through the four classical branches of philosophy. Methodology, not metaphysics.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "trends:fetch": "tsx src/index.ts fetch",
    "trends:analyze": "tsx src/index.ts analyze",
    "trends:digest": "tsx src/index.ts digest",
    "trends:run": "tsx src/index.ts run",
    "trends:serve": "tsx src/index.ts serve"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.5.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
